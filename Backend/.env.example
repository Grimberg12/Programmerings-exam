# Copy this file to .env and fill in the values.
# Example for Azure SQL (SQL Server) connection string:
# AZURE_SQL_CONNECTION_STRING="Server=tcp:<your-server>.database.windows.net,1433;Initial Catalog=<your-db>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"

# Port the backend should listen on
PORT=3000
